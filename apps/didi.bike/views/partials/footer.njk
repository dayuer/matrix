{% set homePrefix = '' if locale == 'en' else '/id' %}

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <div class="footer-logo">
          <!-- DIDI.BIKE Logo Wordmark SVG -->
          <svg
            viewBox="0 0 320 48"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="footer-logo-svg"
            width="192"
            height="29"
            aria-label="DIDI.BIKE"
            role="img"
          >
            <path
              d="M0 6h14c11.5 0 19 7.5 19 18s-7.5 18-19 18H0V6zm9 7.5v21h4.5c7 0 11-4.5 11-10.5s-4-10.5-11-10.5H9z"
              fill="currentColor"
            />
            <rect x="40" y="6" width="9" height="36" rx="1" fill="currentColor" />
            <path
              d="M58 6h14c11.5 0 19 7.5 19 18s-7.5 18-19 18H58V6zm9 7.5v21h4.5c7 0 11-4.5 11-10.5s-4-10.5-11-10.5H67z"
              fill="currentColor"
            />
            <rect x="98" y="6" width="9" height="36" rx="1" fill="currentColor" />
            <circle cx="120" cy="38" r="4.5" fill="#00d4ff" />
            <circle cx="120" cy="38" r="8" fill="#00d4ff" opacity="0.15" />
            <path
              d="M134 6h15c7.5 0 12 3.8 12 9.5 0 4-2.2 6.8-5.8 8.2 4.2 1.2 7 4.5 7 9.3 0 6.2-5 9-13 9h-15.2V6zm9 7v8.5h5c3.5 0 5.2-1.8 5.2-4.3S151.5 13 148 13h-5zm0 15v9h6c4 0 6-2 6-4.5S153 28 149 28h-6z"
              fill="currentColor"
            />
            <rect x="170" y="6" width="9" height="36" rx="1" fill="currentColor" />
            <path
              d="M188 6h9v14.5L211.5 6H223l-16 16.5L224 42h-12l-12-14.5V42h-9V6z"
              fill="currentColor"
              opacity="0.95"
            />
            <path
              d="M228 6h28v7.5h-19v7h16v7h-16v7.5h20V42h-29V6z"
              fill="currentColor"
            />
          </svg>
        </div>
        <p class="footer-brand-desc">{{ dict.footer.tagline or 'Data-Integrated Dynamic Intelligence' }}</p>
        <p class="footer-brand-sub">{{ dict.footer.taglineSub or 'Precision cycling telemetry hardware' }}</p>
      </div>

      <!-- Quick Links Column -->
      <div class="footer-col">
        <h4 class="footer-col-title">{{ dict.footer.quickLinks or 'Quick Links' }}</h4>
        <nav aria-label="Quick links">
          <ul>
            <li><a href="{{ homePrefix }}/">{{ dict.footer.home or 'Home' }}</a></li>
            {% for item in site.nav %}
              {% set navKey = item.key %}
              {% if item.key == 'use-cases' %}
                {% set navKey = 'useCases' %}
              {% endif %}
              {% if item.key != 'sensor' and item.key != 'about' %}
                <li>
                  <a href="{{ homePrefix }}{{ item.href }}">
                    {{ dict.nav[navKey] or item.text }}
                  </a>
                </li>
              {% endif %}
            {% endfor %}
            <li><a href="{{ homePrefix }}/about">{{ dict.nav.about or 'About' }}</a></li>
          </ul>
        </nav>
      </div>

      <!-- Legal Column -->
      <div class="footer-col">
        <h4 class="footer-col-title">{{ dict.footer.legal or 'Legal' }}</h4>
        <nav aria-label="Legal pages">
          <ul>
            <li><a href="{{ homePrefix }}/legal/privacy-policy" rel="nofollow">{{ dict.footer.privacyPolicy or 'Privacy Policy' }}</a></li>
            <li><a href="{{ homePrefix }}/legal/terms-of-service" rel="nofollow">{{ dict.footer.termsOfService or 'Terms of Service' }}</a></li>
            <li><a href="{{ homePrefix }}/legal/cookie-policy" rel="nofollow">{{ dict.footer.cookiePolicy or 'Cookie Policy' }}</a></li>
            <li><a href="{{ homePrefix }}/legal/trademark-notice" rel="nofollow">{{ dict.footer.trademarkNotice or 'Trademark Notice' }}</a></li>
          </ul>
        </nav>
      </div>

      <!-- Connect Column -->
      <div class="footer-col">
        <h4 class="footer-col-title">{{ dict.footer.connect or 'Connect' }}</h4>
        <div class="footer-social-links">
          <span class="footer-social-link">LinkedIn</span>
          <span class="footer-social-link">Twitter</span>
          <span class="footer-social-link">Strava</span>
        </div>
        <p style="font-size: 0.7rem; color: var(--color-text-tertiary); margin-top: 8px; font-family: var(--font-mono);">
          {{ dict.footer.linksSoon or 'Links coming soon' }}
        </p>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="footer-disclaimer">
      <p>{{ dict.footer.disclaimer or 'DIDI.BIKE is an independent sports technology brand.' }}</p>
    </div>

    <!-- Bottom Copyright -->
    <div class="footer-bottom">
      <p>{{ dict.footer.copyright or '© 2026 DIDI.BIKE. All rights reserved.' }}</p>
    </div>
  </div>
</footer>
