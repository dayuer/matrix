# 复制为 .env 后按需修改
PORT=3000

# 所有绝对 URL（canonical / OG / JSON-LD）的基准域名，换域名只改这一处
SITE_BASE_URL=https://www.edaijia.cn

# 静态资源指纹；留空则启动时自动用时间戳
ASSET_VERSION=

# 埋点：none | ga4 | baidu | sensors
ANALYTICS_PROVIDER=none
ANALYTICS_ID=

# ── 叫车下单 BFF · token 与 magic link ──
# token 签名密钥（生产必须设置为高熵随机串，勿用默认）
TOKEN_SECRET=
# magic link 短信里的链接基准域名（短信中点开的地址）
MAGIC_LINK_BASE=https://m.edaijia.cn

# ── 真实 provider 开关（不设则用内存 fake，便于本地/CI） ──
# 定位：edaijia 开启真实 GPS 逆地理
GEO_PROVIDER=
# 短信网关：http 开启真实短信发送
SMS_PROVIDER=
SMS_GATEWAY_URL=
SMS_GATEWAY_TOKEN=
# 运营商一键登录：http 开启真实号码认证校验
CARRIER_PROVIDER=
CARRIER_API_URL=
CARRIER_API_KEY=
# AI 解析：http 开启真实 LLM（OpenAI 兼容），失败自动降级正则解析
LLM_PROVIDER=
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# 订单文件持久化路径（设置则重启不丢在途单；留空为纯内存）
ORDER_STORE_FILE=
