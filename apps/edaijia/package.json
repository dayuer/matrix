{
  "name": "edaijia-website",
  "version": "1.0.0",
  "private": true,
  "description": "e代驾官网 · Express + Nunjucks 组件化服务端（TypeScript）",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build": "npm run build:server",
    "dev": "tsx watch src/server.ts",
    "export": "tsx src/export.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prestart": "npm run build",
    "start": "node dist/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@matrix/site-kit": "1.0.0",
    "@matrix/theme-journal": "1.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/nunjucks": "^3.2.6",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
