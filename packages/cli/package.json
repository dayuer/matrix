{
  "name": "@matrix/cli",
  "version": "1.0.0",
  "private": true,
  "description": "内容矩阵 CLI：把 sites/<站点>（site.yaml + content/*.yaml|*.md 纯数据目录）加载为 SiteDefinition，统一 dev/export。比 WordPress 轻的静态内容发布入口。",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "matrix": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@matrix/site-kit": "1.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
