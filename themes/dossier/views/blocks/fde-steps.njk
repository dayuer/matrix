{% set d = block.data %}
{% set h = d.head %}
<section class="section" id="{{ d.anchor or 'fde' }}">
  {% include "blocks/_section-head.njk" %}

  <ol class="steps">
    {% for step in d.steps %}
      <li class="step reveal">
        <div class="step__index">
          <span class="step__num mono">{{ step.num }}</span>
        </div>
        <div class="step__body">
          <h3 class="step__title">{{ step.title }}</h3>
          <p class="step__desc">{{ step.desc }}</p>
          <ul class="step__list">
            {% for item in step.subItems %}<li>{{ item }}</li>{% endfor %}
          </ul>
        </div>
      </li>
    {% endfor %}
  </ol>
</section>
