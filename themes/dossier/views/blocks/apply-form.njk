{% set d = block.data %}
{% set f = d.form.fields %}
<section class="section apply" id="{{ d.anchor or 'apply' }}">
  <div class="apply__inner reveal">
    <div class="apply__intro">
      <div class="label"><span class="label__no mono">{{ d.head.no }}</span><span class="label__tick" aria-hidden="true"></span><span class="label__txt mono">{{ d.head.tag }}</span></div>
      <h2 class="section__title">{{ d.head.title }}</h2>
      <p class="section__lead">{{ d.head.lead }}</p>
      <ul class="apply__promise">
        {% for p in d.promise %}<li><span class="mono">{{ p.no }}</span>{{ p.text }}</li>{% endfor %}
      </ul>
    </div>

    <form id="partnership-form" class="apply__form" novalidate>
      <div class="field">
        <label for="companyName">{{ f.companyName.label }}</label>
        <input type="text" id="companyName" name="companyName" placeholder="{{ f.companyName.placeholder }}" required>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="contactName">{{ f.contactName.label }}</label>
          <input type="text" id="contactName" name="contactName" placeholder="{{ f.contactName.placeholder }}" required>
        </div>
        <div class="field">
          <label for="contactEmail">{{ f.contactEmail.label }}</label>
          <input type="email" id="contactEmail" name="contactEmail" placeholder="{{ f.contactEmail.placeholder }}" required>
        </div>
      </div>
      <div class="field">
        <label for="systemType">{{ f.systemType.label }}</label>
        <select id="systemType" name="systemType" required>
          <option value="" disabled selected>{{ f.systemType.placeholder }}</option>
          {% for opt in f.systemType.options %}<option value="{{ opt.value }}">{{ opt.text }}</option>{% endfor %}
        </select>
      </div>
      <div class="field">
        <label for="description">{{ f.description.label }}</label>
        <textarea id="description" name="description" rows="4" placeholder="{{ f.description.placeholder }}" required></textarea>
      </div>
      <button type="submit" class="btn btn--primary btn--block">{{ d.form.submitText }} <span aria-hidden="true">→</span></button>
      <p id="form-status" class="form-status" role="status" aria-live="polite" hidden></p>
    </form>
  </div>
</section>
