{# 复用的区块标题：期望 h = { no, tag, title, lead } #}
<header class="section__head reveal">
  <div class="label"><span class="label__no mono">{{ h.no }}</span><span class="label__tick" aria-hidden="true"></span><span class="label__txt mono">{{ h.tag }}</span></div>
  <h2 class="section__title">{{ h.title }}</h2>
  <p class="section__lead">{{ h.lead }}</p>
</header>
