{
  "name": "@matrix/theme-company",
  "version": "1.0.0",
  "private": true,
  "description": "内容矩阵主题：通用企业官网（Company）—— Bento 卡片、多页 block 占位与博客板块。纯表现层，零业务内容；由 sites/<站点> 数据驱动，经 @matrix/cli 渲染。",
  "main": "dist/theme.js",
  "types": "dist/theme.d.ts",
  "exports": { ".": { "types": "./dist/theme.d.ts", "default": "./dist/theme.js" } },
  "scripts": {
    "build:manifest": "tsc -p tsconfig.json",
    "build:client": "tsc -p tsconfig.client.json",
    "build": "npm run build:manifest && npm run build:client"
  },
  "engines": { "node": ">=20" },
  "dependencies": { "@matrix/site-kit": "1.0.0" },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
