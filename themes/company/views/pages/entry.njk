{% extends "layouts/base.njk" %}
{% block content %}

  <main class="entry-page">

    <!-- Hero Header -->
    <section class="recruit-header" data-reveal>
      <p class="section-header__label">司机招募</p>
      <h1 class="section-header__title">成为{{ site.brand.name }}司机</h1>
      <p class="section-header__desc">加入全国 300+ 城市的专业代驾司机团队，时间自由、收入丰厚、保障齐全。微信扫码即可报名，开启您的代驾事业。</p>
    </section>

    <!-- 招募优势 -->
    <section class="recruit-benefits" data-reveal>
      <h2 class="recruit-section-title">为什么加入我们</h2>
      <p class="recruit-section-desc">{{ site.brand.name }}为每位合作司机提供行业领先的全方位支持体系</p>

      <div class="benefit-grid">
        <div class="benefit-card">
          <div class="benefit-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <h3 class="benefit-card__title">时间自由</h3>
          <p class="benefit-card__desc">灵活接单，工作时间完全自主安排，兼职全职皆可</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </div>
          <h3 class="benefit-card__title">收入丰厚</h3>
          <p class="benefit-card__desc">多劳多得，订单结算透明即时，收入上不封顶</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h3 class="benefit-card__title">保障齐全</h3>
          <p class="benefit-card__desc">代驾保险全覆盖，专业安全培训体系，驾车零风险</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
              <line x1="12" y1="18" x2="12.01" y2="18"></line>
            </svg>
          </div>
          <h3 class="benefit-card__title">智能派单</h3>
          <p class="benefit-card__desc">APP 智能匹配就近订单，减少空驶高效接单</p>
        </div>
      </div>
    </section>

    <!-- 报名流程 -->
    <section class="recruit-flow" data-reveal>
      <div class="recruit-flow__inner">
        <h2 class="recruit-section-title">报名流程</h2>
        <p class="recruit-section-desc">三步轻松加入，开启您的代驾事业</p>

        <div class="flow-steps">
          <div class="flow-step">
            <div class="flow-step__number">1</div>
            <h3 class="flow-step__title">微信报名</h3>
            <p class="flow-step__desc">扫码关注「{{ site.brand.name }}司机服务平台」公众号，选择"加入我们"在线填写报名信息</p>
          </div>
          <div class="flow-step">
            <div class="flow-step__number">2</div>
            <h3 class="flow-step__title">预约路考</h3>
            <p class="flow-step__desc">选择所在城市及合适的时间段，参加线下实操路考</p>
          </div>
          <div class="flow-step">
            <div class="flow-step__number">3</div>
            <h3 class="flow-step__title">签约上岗</h3>
            <p class="flow-step__desc">通过考核后在线签约并预存信息服务费，即可即刻接单</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 报名须知 -->
    <section class="recruit-notice" data-reveal>
      <h2 class="recruit-section-title">报名须知</h2>

      <div class="notice-box">
        <div class="notice-box__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
          报名条件
        </div>
        <ul class="notice-list">
          <li>报名信息必须<strong>真实有效</strong>，且满足近 3 年安全驾驶记录</li>
          <li>确认自愿使用平台信息服务</li>
          <li>需持有以下有效证件：<strong>身份证、驾驶证</strong></li>
          <li>根据城市不同，同意在成功签约后扣缴或自备<strong>物料装备费（如服装、头盔等）</strong></li>
          <li>当终止提供信息服务时，处理周期为 <strong>90 天</strong></li>
          <li>年龄需在 <strong>18 - 60 周岁</strong>之间</li>
        </ul>
      </div>

      <div class="notice-box">
        <div class="notice-box__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
          相关协议
        </div>
        <ul class="notice-list">
          <li><a href="{{ site.brand.userRuleUrl }}" target="_blank" style="color: #0071e3; text-decoration: none;">《{{ site.brand.name }}信息服务平台用户使用规则》</a></li>
          <li><a href="{{ site.brand.driverAgreementUrl }}" target="_blank" style="color: #0071e3; text-decoration: none;">《代驾服务协议》</a></li>
          <li><a href="{{ site.brand.infoAgreementUrl }}" target="_blank" style="color: #0071e3; text-decoration: none;">《信息服务协议》</a></li>
        </ul>
      </div>
    </section>

    <!-- CTA -->
    <section class="recruit-cta" data-reveal>
      <div class="recruit-cta__inner">
        <h2 class="recruit-cta__title">准备好加入了吗？</h2>
        <p class="recruit-cta__desc">通过微信公众号即可在线报名，扫码开启您的代驾事业。</p>

        <!-- 微信二维码扫码区 -->
        <div class="recruit-qr">
          <div class="recruit-qr__card">
            <img src="{{ basePath }}/images/qr-driver-wechat.png" alt="{{ site.brand.name }}司机服务平台微信公众号二维码" class="recruit-qr__img">
            <p class="recruit-qr__hint">微信扫码关注「{{ site.brand.name }}司机服务平台」</p>
            <p class="recruit-qr__steps">关注公众号后选择 "加入我们" → "点击报名" 开始线上报名流程</p>
          </div>
        </div>

        <span class="recruit-cta__phone">司机咨询热线：<a href="tel:010-58103866">010-58103866</a> · 客服热线：<a href="tel:95139">95139</a></span>
      </div>
    </section>

  </main>

{% endblock %}
