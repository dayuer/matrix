{% extends "layouts/base.njk" %}
{% block content %}

  <span id="top"></span>

  {# ── 移动端首屏：大按钮叫车入口 ── #}
  <section class="mobile-hero" data-screen-label="MobileHero">
    <div class="mobile-hero__inner">
      <img src="{{ basePath }}/images/logo.png" alt="e代驾" class="mobile-hero__logo">
      <h1 class="mobile-hero__title">酒后代驾<br>一键即达</h1>
      <p class="mobile-hero__subtitle">覆盖全国 300+ 城市 · 实惠更安全</p>
      <a href="{{ basePath }}/order" class="mobile-hero__cta" data-track="order_click" data-track-platform="mobile-hero">
        <span class="mobile-hero__cta-icon">🚗</span>
        叫代驾
      </a>
      <p class="mobile-hero__hint">无需下载 App，在线说一句话即可下单</p>
    </div>
  </section>

  {# ── 快速入口卡片 ── #}
  <section class="mobile-quick" data-reveal>
    <div class="mobile-quick__grid">
      <a href="{{ basePath }}/order" class="mobile-quick__card">
        <span class="mobile-quick__icon">🍺</span>
        <span class="mobile-quick__label">酒后代驾</span>
      </a>
      <a href="tel:95139" class="mobile-quick__card">
        <span class="mobile-quick__icon">📞</span>
        <span class="mobile-quick__label">电话叫车</span>
      </a>
      <a href="{{ basePath }}/questions" class="mobile-quick__card">
        <span class="mobile-quick__icon">❓</span>
        <span class="mobile-quick__label">常见问答</span>
      </a>
      <a href="{{ basePath }}/entry" class="mobile-quick__card">
        <span class="mobile-quick__icon">🙋</span>
        <span class="mobile-quick__label">司机招募</span>
      </a>
    </div>
  </section>

  {# ── 信任指标 ── #}
  <section class="mobile-trust" data-reveal>
    <div class="mobile-trust__row">
      <div class="mobile-trust__stat">
        <span class="mobile-trust__num" data-count="300">300</span>
        <span class="mobile-trust__unit">+</span>
        <span class="mobile-trust__desc">覆盖城市</span>
      </div>
      <div class="mobile-trust__stat">
        <span class="mobile-trust__num" data-count="200">200</span>
        <span class="mobile-trust__unit">万+</span>
        <span class="mobile-trust__desc">注册司机</span>
      </div>
      <div class="mobile-trust__stat">
        <span class="mobile-trust__num" id="mobileTrustYears">十五</span>
        <span class="mobile-trust__unit">年</span>
        <span class="mobile-trust__desc">品牌沉淀</span>
      </div>
    </div>
  </section>

  {# ── 底部下载提示 ── #}
  <section class="mobile-download" data-reveal>
    <p class="mobile-download__text">下载 e代驾 App 享更多服务</p>
    <div class="mobile-download__badges">
      <a href="{{ site.brand.appStoreUrl }}" class="mobile-download__badge" data-track="download_ios" target="_blank" rel="noopener">
        <img src="{{ basePath }}/images/badge-appstore.svg" alt="App Store 下载" onerror="this.textContent='App Store'">
      </a>
      <a href="{{ site.brand.androidApkUrl }}" class="mobile-download__badge" data-track="download_android" target="_blank" rel="noopener">
        Android 下载
      </a>
    </div>
  </section>

{% endblock %}
