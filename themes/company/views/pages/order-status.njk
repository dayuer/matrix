{% extends "layouts/order-base.njk" %}

{% block content %}
<main class="status-page">

  <header class="status-header">
    <div class="status-header__brand">
      <img src="{{ basePath }}/images/logo.png" alt="e代驾" height="28">
    </div>
    <h1 class="status-header__title">订单状态</h1>
    <p class="status-header__phone" id="maskedPhone"></p>
  </header>

  {# ── 路线摘要 ── #}
  <section class="status-route" id="routeSection">
    <div class="status-route__point">
      <span class="status-route__dot status-route__dot--origin"></span>
      <div>
        <span class="status-route__label">起点</span>
        <span class="status-route__name" id="routeOrigin">—</span>
      </div>
    </div>
    <div class="status-route__line"></div>
    <div class="status-route__point">
      <span class="status-route__dot status-route__dot--dest"></span>
      <div>
        <span class="status-route__label">终点</span>
        <span class="status-route__name" id="routeDest">—</span>
      </div>
    </div>
  </section>

  {# ── 状态时间线 ── #}
  <section class="status-timeline" id="timeline">
    {# 由 JS 根据 API 响应动态渲染 #}
    <div class="status-timeline__loading">
      <div class="status-timeline__spinner"></div>
      <p>正在加载订单状态…</p>
    </div>
  </section>

  {# ── 操作区 ── #}
  <section class="status-actions" id="actions">
    <button class="status-actions__cancel" id="cancelBtn" style="display:none">取消订单</button>
    <div class="status-actions__contact" id="contactDriver" style="display:none">
      <p>如需更改目的地，请上车后直接告知司机</p>
    </div>
    <a href="tel:95139" class="status-actions__hotline" data-track="status_call_95139">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 00-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 004.168 6.608 17.569 17.569 0 006.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 00-.063-1.015l-2.307-1.794a.678.678 0 00-.58-.122l-2.19.547a1.745 1.745 0 01-1.657-.459L5.482 8.062a1.745 1.745 0 01-.46-1.657l.548-2.19a.678.678 0 00-.122-.58L3.654 1.328z"/></svg>
      拨打客服 95139
    </a>
  </section>

  {# ── 终态提示 ── #}
  <section class="status-terminal" id="terminalPanel" style="display:none">
    <p class="status-terminal__msg" id="terminalMsg"></p>
    <a href="{{ basePath }}/" class="status-terminal__retry">重新叫车</a>
  </section>

</main>

{% block extraScript %}
<script>window.__QUERY_TOKEN__ = {{ queryToken | dump | safe }};</script>
<script src="{{ basePath }}/order-status.js?v={{ assetVersion }}"></script>
{% endblock %}
{% endblock %}
