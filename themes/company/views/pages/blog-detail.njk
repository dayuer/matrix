{% extends "layouts/base.njk" %}
{% block content %}

  <main class="blog-detail-page">

    <!-- 顶部导航面包屑 -->
    <div class="blog-breadcrumb-container">
      <nav class="blog-breadcrumb">
        <a href="{{ basePath }}/">首页</a>
        <span class="blog-breadcrumb__separator">&gt;</span>
        <a href="{{ basePath }}/blog">行业洞察</a>
        <span class="blog-breadcrumb__separator">&gt;</span>
        <span class="blog-breadcrumb__current">{{ article.title }}</span>
      </nav>
    </div>

    <!-- 博客正文区 -->
    <section class="blog-detail-content">
      <div class="blog-container">

        <!-- 左侧博客主体 -->
        <article class="blog-article" data-reveal>
          <header class="blog-article__header">
            <div class="blog-card__meta">
              <span class="blog-card__category blog-card__category--{{ article.cluster }}">
                {% if article.cluster == 'pricing' %}收费指南
                {% elif article.cluster == 'safety' %}安全责任
                {% elif article.cluster == 'scenarios' %}商务场景
                {% elif article.cluster == 'recruit' %}司机招募
                {% else %}行业动态{% endif %}
              </span>
              <span class="blog-card__date">发布时间：{{ article.displayDate }}</span>
            </div>
            <h1 class="blog-article__title">{{ article.title }}</h1>
          </header>

          <!-- 富文本 Markdown 正文渲染 -->
          <div class="blog-article__body markdown-body">
            {{ article.contentHtml | safe }}
          </div>

          <!-- 权威作者签名卡片 (EEAT) -->
          <div class="blog-article__author-card">
            <div class="author-card__avatar">
              <span>{{ article.author.name.slice(0, 1) }}</span>
            </div>
            <div class="author-card__info">
              <div class="author-card__name">{{ article.author.name }}</div>
              <div class="author-card__bio">{{ article.author.bio }}</div>
            </div>
          </div>
        </article>

        <!-- 右侧侧边栏 -->
        <aside class="blog-sidebar">
          
          <!-- 推荐阅读 (Related Articles) -->
          {% if relatedArticles.length > 0 %}
            <div class="sidebar-widget">
              <h3 class="sidebar-widget__title">相关推荐</h3>
              <ul class="sidebar-widget__list">
                {% for related in relatedArticles %}
                  <li class="sidebar-widget__item">
                    <a href="{{ basePath }}/blog/{{ related.slug }}" class="sidebar-widget__link">
                      {{ related.title }}
                    </a>
                    <span class="sidebar-widget__date">{{ related.displayDate }}</span>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <div class="sidebar-card">
            <h3 class="sidebar-card__title">酒后代驾 一键即达</h3>
            <p class="sidebar-card__desc">覆盖全国300+城市，千万险种安全护航。</p>
            <a href="{{ basePath }}/order" class="sidebar-card__btn sidebar-card__btn--primary">立即叫车</a>
          </div>

        </aside>

      </div>
    </section>

  </main>

{% endblock %}
