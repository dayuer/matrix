{# 负责人名片宏：partner / serves 共用。regions 可选。 #}
{% macro managerCard(m) %}
<div class="manager-card">
  {% if m.regions %}<div class="manager-card__regions">{{ m.regions }}</div>{% endif %}
  <div class="manager-card__body">
    <div class="manager-card__avatar">{{ m.avatar }}</div>
    <h3 class="manager-card__name">{{ m.name }}</h3>
    <p class="manager-card__title">{{ m.title }}</p>
  </div>
  <div class="manager-card__actions">
    <a href="tel:{{ m.phone }}" class="manager-btn manager-btn--primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      拨打电话
    </a>
    {% if m.wechat %}
    <button class="manager-btn manager-btn--secondary copy-btn" data-copy="{{ m.wechat }}" data-type="微信" data-track="copy_contact" data-track-type="wechat">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      复制微信
    </button>
    {% endif %}
    <button class="manager-btn manager-btn--secondary copy-btn" data-copy="{{ m.email }}" data-type="邮箱" data-track="copy_contact" data-track-type="email">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      复制邮箱
    </button>
  </div>
</div>
{% endmacro %}
