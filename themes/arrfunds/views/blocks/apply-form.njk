{% set d = block.data %}
{% set h = d.head %}
{% set f = d.form.fields %}
{% set selectField = f.systemType or f.currentArr %}
{% set descField = f.description or f.aiDesc %}

<section class="apply-section" id="{{ d.anchor or 'apply' }}">
  <div class="apply-container" data-reveal>
    <div class="apply-card">
      <div class="apply-card__info">
        <h2 class="apply-card__title">{{ d.title or h.title }}</h2>
        <p class="apply-card__desc">{{ d.desc or d.lead or h.lead }}</p>
        <div class="apply-highlights">
          {% if d.highlights %}
            {% for hl in d.highlights %}
              <div class="highlight-item">✓ {{ hl }}</div>
            {% endfor %}
          {% elif d.promise %}
            {% for p in d.promise %}
              <div class="highlight-item">✓ {{ p.text or p }}</div>
            {% endfor %}
          {% endif %}
        </div>
      </div>
      <div class="apply-card__form">
        <form class="lead-form" id="applyForm">
          <div class="form-group">
            <label for="companyName">{{ f.companyName.label }}</label>
            <input type="text" id="companyName" required placeholder="{{ f.companyName.placeholder }}">
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="contactName">{{ f.contactName.label or "联系人姓名" }}</label>
              <input type="text" id="contactName" required placeholder="{{ f.contactName.placeholder or "请输入您的姓名" }}">
            </div>
            <div class="form-group">
              <label for="contactEmail">{{ f.contactEmail.label or "工作邮箱" }}</label>
              <input type="email" id="contactEmail" required placeholder="{{ f.contactEmail.placeholder }}">
            </div>
          </div>
          {% if selectField %}
          <div class="form-group">
            <label for="systemType">{{ selectField.label }}</label>
            <select id="systemType" required>
              <option value="" disabled selected>{{ selectField.placeholder }}</option>
              {% for opt in selectField.options %}
                <option value="{{ opt.value }}">{{ opt.text }}</option>
              {% endfor %}
            </select>
          </div>
          {% endif %}
          <div class="form-group">
            <label for="aiDesc">{{ descField.label }}</label>
            <textarea id="aiDesc" placeholder="{{ descField.placeholder }}" rows="3" class="form-textarea"></textarea>
          </div>
          <button type="submit" class="form-submit-btn" id="submitBtn">{{ d.form.submitText }}</button>
          <p class="form-notice">{{ d.form.notice or "提交后我们的架构师团队将对您的系统进行保密诊断评估。" }}</p>
        </form>
        <div class="form-success-toast" id="successToast">
          <div class="success-icon">✓</div>
          <h4>{{ d.toast.title or "申请提交成功" }}</h4>
          <p>{{ d.toast.desc or "资深架构师将在 2 个工作日内与您对接。" }}</p>
        </div>
      </div>
    </div>
  </div>
</section>
