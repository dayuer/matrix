{% set d = block.data %}
<section class="features-section" id="{{ d.anchor or 'faq' }}">
  <div class="section-container">
    <div class="section-header" data-reveal>
      <p class="section-header__label">{{ d.head.tag }}</p>
      <h2 class="section-header__title">{{ d.head.title }}</h2>
      <p class="section-header__desc">{{ d.head.lead }}</p>
    </div>

    <div class="bento-grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));">
      {% for item in d.faqs %}
        <div class="bento-card" data-reveal style="padding: 30px; text-align: left;">
          <span class="bento-card__tag" style="background: rgba(212, 175, 55, 0.1); color: var(--accent); font-weight: bold;">Q{{ loop.index }}</span>
          <h3 class="bento-card__title" style="margin-top: 12px; font-size: 1.2rem; line-height: 1.4;">{{ item.question }}</h3>
          <p class="bento-card__desc" style="margin-top: 12px; line-height: 1.6; color: var(--text-muted);">{{ item.answer }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
