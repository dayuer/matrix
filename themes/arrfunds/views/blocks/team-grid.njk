{% set d = block.data %}
<section class="features-section" id="{{ d.anchor or 'team' }}">
  <div class="section-container">
    <div class="section-header" data-reveal>
      <p class="section-header__label">{{ d.head.tag }}</p>
      <h2 class="section-header__title">{{ d.head.title }}</h2>
      <p class="section-header__desc">{{ d.head.lead }}</p>
    </div>

    <div class="bento-grid">
      {% for team in d.teams %}
        <div class="bento-card bento-card--wide" data-reveal style="text-align: left;">
          <span class="bento-card__tag" style="background: rgba(212, 175, 55, 0.1); color: var(--accent); border: 1px solid rgba(212, 175, 55, 0.2);">{{ team.role }}</span>
          <h3 class="bento-card__title" style="margin-top: 16px; font-size: 1.3rem;">{{ team.name }}</h3>
          <p class="bento-card__desc" style="margin-bottom: 20px;">{{ team.desc }}</p>
          <ul class="bento-list" style="padding-left: 18px; color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            {% for point in team.points %}
              <li style="margin-bottom: 8px; list-style-type: square;">{{ point }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
