{% set data = block.data or dict.sensor %}
<section id="sensor" class="section sensor">
  <div class="sensor-glow-orb"></div>
  <div class="container">
    <div class="section-header">
      <span class="section-label">{{ data.label }}</span>
      <h2 class="section-title">{{ data.title }}</h2>
      <p class="section-desc">{{ data.desc }}</p>
    </div>

    <!-- Tabs Container -->
    <div class="sensor-tabs" id="sensorTabs">
      <button class="sensor-tab active" data-tab="specs">
        {{ data.tabSpecs }}
      </button>
      <button class="sensor-tab" data-tab="accuracy">
        {{ data.tabAccuracy }}
      </button>
      <button class="sensor-tab" data-tab="benchmark">
        {{ data.tabBenchmark }}
      </button>
    </div>

    <!-- Specs Tab Panel -->
    <div class="sensor-panel" id="panel-specs">
      <div class="sensor-specs-grid">
        {% for s in data.specs %}
          <div class="sensor-spec-item">
            <span class="sensor-spec-label">{{ s.label }}</span>
            <span class="sensor-spec-value">{{ s.value }}</span>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Accuracy Tab Panel -->
    <div class="sensor-panel" id="panel-accuracy" style="display: none;">
      <div class="sensor-accuracy-grid">
        {% for a in data.accuracy %}
          <div class="glass-card sensor-accuracy-card">
            <div class="sensor-acc-value">{{ a.value }}</div>
            <div class="sensor-acc-label">{{ a.label }}</div>
            <div class="sensor-acc-desc">{{ a.desc }}</div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Benchmark Tab Panel -->
    <div class="sensor-panel" id="panel-benchmark" style="display: none;">
      <div class="sensor-bench-table">
        <div class="sensor-bench-row sensor-bench-header">
          {% for h in data.benchmarkHeaders %}
            <span>{{ h }}</span>
          {% endfor %}
        </div>
        {% for c in data.comparison %}
          <div class="sensor-bench-row">
            <span class="sensor-bench-metric">{{ c.metric }}</span>
            <span class="sensor-bench-us">{{ c.us }}</span>
            <span class="sensor-bench-them">{{ c.them }}</span>
            <span class="sensor-bench-gain">{{ c.gain }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
